generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  BUSINESS_OWNER
  ADMIN
}

enum BusinessStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELLED
  REFUNDED
}

enum PriceRange {
  BUDGET
  MODERATE
  EXPENSIVE
  LUXURY
}

enum PlanType {
  FREE
  BASIC
  PRO
}

enum TransactionType {
  EARN
  REDEEM
  EXPIRE
  BONUS
  ADMIN_ADJUST
}

// ─── AUTH ───────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── USERS ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  reviews        Review[]
  reservations   Reservation[]
  tickets        Ticket[]
  pointsBalance  PointsBalance?
  pointsTx       PointsTransaction[]
  favorites      Favorite[]
  ownedBusiness  Business[]
}

// ─── CATALOG ────────────────────────────────────────────────────────────────

model City {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  region      String     @default("Los Lagos")
  lat         Float?
  lng         Float?
  image       String?
  description String?
  businesses  Business[]
  events      Event[]
}

model Category {
  id       String     @id @default(cuid())
  name     String     @unique
  slug     String     @unique
  icon     String?
  color    String?
  order    Int        @default(0)
  businesses Business[]
}

// ─── BUSINESSES ─────────────────────────────────────────────────────────────

model Business {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?        @db.Text
  shortDesc   String?
  status      BusinessStatus @default(PENDING)
  priceRange  PriceRange?
  verified    Boolean        @default(false)

  cityId      String
  city        City           @relation(fields: [cityId], references: [id])
  address     String?
  lat         Float?
  lng         Float?

  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  tags        String[]

  phone       String?
  whatsapp    String?
  email       String?
  website     String?
  instagram   String?
  facebook    String?

  coverImage  String?
  logo        String?
  photos      BusinessPhoto[]
  menuUrl     String?
  hours       BusinessHours[]

  pointsPerPeso    Float   @default(0.01)
  pointsEnabled    Boolean @default(false)

  ownerId     String?
  owner       User?          @relation(fields: [ownerId], references: [id])
  reviews     Review[]
  reservations Reservation[]
  events      Event[]
  favorites   Favorite[]
  pointsTx    PointsTransaction[]

  avgRating   Float    @default(0)
  reviewCount Int      @default(0)
  featured    Boolean  @default(false)
  plan        PlanType @default(FREE)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([cityId])
  @@index([categoryId])
  @@index([slug])
}

model BusinessPhoto {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  url        String
  alt        String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}

model BusinessHours {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  openTime   String?
  closeTime  String?
  closed     Boolean  @default(false)
}

// ─── REVIEWS ────────────────────────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?  @db.Text
  photos     String[]
  helpful    Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, userId])
  @@index([businessId])
}

// ─── RESERVATIONS ───────────────────────────────────────────────────────────

model Reservation {
  id           String            @id @default(cuid())
  businessId   String
  business     Business          @relation(fields: [businessId], references: [id])
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  date         DateTime
  time         String
  partySize    Int
  status       ReservationStatus @default(PENDING)
  notes        String?
  confirmCode  String            @unique @default(cuid())
  reminderSent Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([businessId])
  @@index([userId])
}

// ─── EVENTS & TICKETS ───────────────────────────────────────────────────────

model Event {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?   @db.Text
  image       String?
  cityId      String
  city        City      @relation(fields: [cityId], references: [id])
  businessId  String?
  business    Business? @relation(fields: [businessId], references: [id])
  startDate   DateTime
  endDate     DateTime?
  location    String?
  lat         Float?
  lng         Float?
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  ticketTypes TicketType[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([cityId])
  @@index([startDate])
}

model TicketType {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  capacity    Int
  sold        Int      @default(0)
  active      Boolean  @default(true)
  tickets     Ticket[]
}

model Ticket {
  id           String       @id @default(cuid())
  ticketTypeId String
  ticketType   TicketType   @relation(fields: [ticketTypeId], references: [id])
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  qrCode       String       @unique @default(cuid())
  status       TicketStatus @default(ACTIVE)
  mpPaymentId  String?
  purchasedAt  DateTime     @default(now())
  usedAt       DateTime?

  @@index([userId])
  @@index([qrCode])
}

// ─── POINTS & REWARDS ───────────────────────────────────────────────────────

model PointsBalance {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int      @default(0)
  lifetime  Int      @default(0)
  level     String   @default("bronze")
  updatedAt DateTime @updatedAt
}

model PointsTransaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  businessId  String?
  business    Business?       @relation(fields: [businessId], references: [id])
  type        TransactionType
  points      Int
  description String?
  reference   String?
  createdAt   DateTime        @default(now())

  @@index([userId])
}

model PointsCampaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  multiplier  Float    @default(1)
  startDate   DateTime
  endDate     DateTime
  active      Boolean  @default(true)
  cityId      String?
  categoryId  String?
  createdAt   DateTime @default(now())
}

// ─── FAVORITES ──────────────────────────────────────────────────────────────

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, businessId])
}
