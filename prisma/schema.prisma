generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  BUSINESS_OWNER
  ADMIN
}

enum BusinessStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELLED
  REFUNDED
}

enum PriceRange {
  BUDGET
  MODERATE
  EXPENSIVE
  LUXURY
}

enum PlanType {
  FREE
  BASIC
  PRO
}

enum TransactionType {
  EARN
  REDEEM
  EXPIRE
  BONUS
  ADMIN_ADJUST
}

// ─── AUTH ───────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── USERS ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  reviews          Review[]
  reservations     Reservation[]
  tickets          Ticket[]
  pointsBalance    PointsBalance?
  pointsTx         PointsTransaction[]
  favorites        Favorite[]
  ownedBusiness    Business[]
  propertyBookings PropertyBooking[]
  activityBookings ActivityBooking[]
}

// ─── CATALOG ────────────────────────────────────────────────────────────────

model City {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  region      String     @default("Los Lagos")
  lat         Float?
  lng         Float?
  image       String?
  description String?
  businesses  Business[]
  events      Event[]
  properties  Property[]
  activities  Activity[]
}

model Category {
  id       String     @id @default(cuid())
  name     String     @unique
  slug     String     @unique
  icon     String?
  color    String?
  order    Int        @default(0)
  businesses Business[]
}

// ─── BUSINESSES ─────────────────────────────────────────────────────────────

model Business {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?        @db.Text
  shortDesc   String?
  status      BusinessStatus @default(PENDING)
  priceRange  PriceRange?
  verified    Boolean        @default(false)

  cityId      String
  city        City           @relation(fields: [cityId], references: [id])
  address     String?
  lat         Float?
  lng         Float?

  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  tags        String[]

  phone       String?
  whatsapp    String?
  email       String?
  website     String?
  instagram   String?
  facebook    String?
  bookingUrl  String?

  coverImage  String?
  logo        String?
  photos      BusinessPhoto[]
  menuUrl     String?
  hours       BusinessHours[]

  amenities        String[]
  pointsPerPeso    Float   @default(0.01)
  pointsEnabled    Boolean @default(false)

  ownerId     String?
  owner       User?          @relation(fields: [ownerId], references: [id])
  reviews     Review[]
  reservations Reservation[]
  events      Event[]
  favorites   Favorite[]
  pointsTx    PointsTransaction[]
  rewards     Reward[]
  products        Product[]
  productSections ProductSection[]
  offers          Offer[]
  coupons         Coupon[]
  analyticsEvents AnalyticsEvent[]

  avgRating   Float    @default(0)
  reviewCount Int      @default(0)
  featured    Boolean  @default(false)
  plan        PlanType @default(FREE)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([cityId])
  @@index([categoryId])
  @@index([slug])
}

model BusinessPhoto {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  url        String
  alt        String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}

model BusinessHours {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  openTime   String?
  closeTime  String?
  closed     Boolean  @default(false)
}

// ─── REVIEWS ────────────────────────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?  @db.Text
  photos     String[]
  helpful    Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, userId])
  @@index([businessId])
}

// ─── RESERVATIONS ───────────────────────────────────────────────────────────

model Reservation {
  id           String            @id @default(cuid())
  businessId   String
  business     Business          @relation(fields: [businessId], references: [id])
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  date         DateTime
  time         String
  partySize    Int
  status       ReservationStatus @default(PENDING)
  notes        String?
  confirmCode  String            @unique @default(cuid())
  reminderSent Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([businessId])
  @@index([userId])
}

// ─── EVENTS & TICKETS ───────────────────────────────────────────────────────

model Event {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?   @db.Text
  image       String?
  cityId      String
  city        City      @relation(fields: [cityId], references: [id])
  businessId  String?
  business    Business? @relation(fields: [businessId], references: [id])
  startDate   DateTime
  endDate     DateTime?
  location    String?
  lat         Float?
  lng         Float?
  isFree      Boolean   @default(true)
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  ticketTypes TicketType[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([cityId])
  @@index([startDate])
}

model TicketType {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  capacity    Int
  sold        Int      @default(0)
  active      Boolean  @default(true)
  tickets     Ticket[]
}

model Ticket {
  id           String       @id @default(cuid())
  ticketTypeId String
  ticketType   TicketType   @relation(fields: [ticketTypeId], references: [id])
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  qrCode       String       @unique @default(cuid())
  status       TicketStatus @default(ACTIVE)
  mpPaymentId  String?
  purchasedAt  DateTime     @default(now())
  usedAt       DateTime?

  @@index([userId])
  @@index([qrCode])
}

// ─── POINTS & REWARDS ───────────────────────────────────────────────────────

model PointsBalance {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int      @default(0)
  lifetime  Int      @default(0)
  level     String   @default("bronze")
  updatedAt DateTime @updatedAt
}

model PointsTransaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  businessId  String?
  business    Business?       @relation(fields: [businessId], references: [id])
  type        TransactionType
  points      Int
  description String?
  reference   String?
  createdAt   DateTime        @default(now())

  @@index([userId])
}

model PointsCampaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  multiplier  Float    @default(1)
  startDate   DateTime
  endDate     DateTime
  active      Boolean  @default(true)
  cityId      String?
  categoryId  String?
  createdAt   DateTime @default(now())
}

// ─── REWARDS ────────────────────────────────────────────────────────────────

model Reward {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title       String
  description String?
  pointsCost  Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([businessId])
}

// ─── FAVORITES ──────────────────────────────────────────────────────────────

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, businessId])
}

// ─── PRODUCT CATALOG ────────────────────────────────────────────────────────

model ProductSection {
  id         String    @id @default(cuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  order      Int       @default(0)
  products   Product[]

  @@index([businessId])
}

model Product {
  id          String          @id @default(cuid())
  businessId  String
  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sectionId   String?
  section     ProductSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  name        String
  description String?
  price       Float?
  image       String?
  available   Boolean         @default(true)
  order       Int             @default(0)
  createdAt   DateTime        @default(now())

  @@index([businessId])
}

// ─── OFFERS ─────────────────────────────────────────────────────────────────

model Offer {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title       String
  description String?
  badge       String?
  validTo     DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([businessId])
}

// ─── COUPONS ────────────────────────────────────────────────────────────────

model Coupon {
  id            String    @id @default(cuid())
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  code          String    @unique
  title         String
  description   String?
  discountType  String    // "PERCENT" | "FIXED"
  discountValue Float
  minPurchase   Float?
  maxUses       Int?
  usedCount     Int       @default(0)
  validFrom     DateTime?
  validTo       DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([businessId])
  @@index([code])
}

// ─── ANALYTICS ──────────────────────────────────────────────────────────────

enum PropertyStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum PropertyBookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REFUNDED
}

enum AnalyticsEventType {
  VIEW
  WHATSAPP_CLICK
  CALL_CLICK
  DIRECTIONS_CLICK
  RESERVATION
}

model AnalyticsEvent {
  id         String             @id @default(cuid())
  businessId String
  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type       AnalyticsEventType
  createdAt  DateTime           @default(now())

  @@index([businessId])
  @@index([businessId, type])
  @@index([createdAt])
}

// ─── RENTALS ────────────────────────────────────────────────────────────────

model Property {
  id                 String         @id @default(cuid())
  title              String
  slug               String         @unique
  description        String?        @db.Text
  shortDesc          String?
  status             PropertyStatus @default(PENDING)
  featured           Boolean        @default(false)

  cityId             String
  city               City           @relation(fields: [cityId], references: [id])
  address            String?
  lat                Float?
  lng                Float?

  pricePerNight      Float
  cleaningFee        Float          @default(0)
  platformFeePercent Float          @default(10)

  maxGuests          Int            @default(2)
  bedrooms           Int            @default(1)
  beds               Int            @default(1)
  bathrooms          Int            @default(1)

  amenities          String[]
  coverImage         String?
  bookingUrl         String?
  photos             PropertyPhoto[]
  bookings           PropertyBooking[]
  blockedDates       PropertyBlockedDate[]

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([cityId])
  @@index([slug])
}

model PropertyPhoto {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String
  alt        String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}

model PropertyBooking {
  id            String               @id @default(cuid())
  propertyId    String
  property      Property             @relation(fields: [propertyId], references: [id])
  userId        String?
  user          User?                @relation(fields: [userId], references: [id])

  checkIn       DateTime
  checkOut      DateTime
  guests        Int
  nights        Int

  nightsPrice   Float
  cleaningFee   Float
  platformFee   Float
  totalPrice    Float

  status        PropertyBookingStatus @default(PENDING)
  mpPaymentId   String?
  confirmCode   String                @unique @default(cuid())

  guestName     String
  guestEmail    String
  guestPhone    String?
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([propertyId])
  @@index([userId])
}

model PropertyBlockedDate {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  reason     String?

  @@unique([propertyId, date])
  @@index([propertyId])
}

// ─── OUTDOOR ACTIVITIES ─────────────────────────────────────────────────────

enum ActivityStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum ActivityBookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REFUNDED
}

enum DifficultyLevel {
  EASY
  MODERATE
  CHALLENGING
  EXPERT
}

model Activity {
  id                 String          @id @default(cuid())
  title              String
  slug               String          @unique
  description        String?         @db.Text
  shortDesc          String?
  status             ActivityStatus  @default(DRAFT)
  featured           Boolean         @default(false)

  cityId             String
  city               City            @relation(fields: [cityId], references: [id])

  category           String
  difficulty         DifficultyLevel?
  duration           String
  pricePerPerson     Float
  minParticipants    Int             @default(1)
  maxParticipants    Int             @default(10)
  platformFeePercent Float           @default(10)

  meetingPoint       String?
  lat                Float?
  lng                Float?

  includes           String[]
  excludes           String[]
  requirements       String?

  coverImage         String?
  photos             ActivityPhoto[]
  sessions           ActivitySession[]

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([cityId])
  @@index([slug])
  @@index([status])
}

model ActivityPhoto {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  url        String
  alt        String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([activityId])
}

model ActivitySession {
  id              String            @id @default(cuid())
  activityId      String
  activity        Activity          @relation(fields: [activityId], references: [id], onDelete: Cascade)
  date            DateTime          @db.Date
  startTime       String
  endTime         String?
  maxParticipants Int
  booked          Int               @default(0)
  active          Boolean           @default(true)
  bookings        ActivityBooking[]

  @@index([activityId])
  @@index([date])
}

model ActivityBooking {
  id            String                @id @default(cuid())
  sessionId     String
  session       ActivitySession       @relation(fields: [sessionId], references: [id])
  userId        String?
  user          User?                 @relation(fields: [userId], references: [id])

  participants  Int
  activityPrice Float
  platformFee   Float
  totalPrice    Float

  status        ActivityBookingStatus @default(PENDING)
  mpPaymentId   String?
  confirmCode   String                @unique @default(cuid())

  guestName     String
  guestEmail    String
  guestPhone    String?
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sessionId])
  @@index([userId])
}
